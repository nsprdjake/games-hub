{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/pride-flag-quiz", "destination": "/pride-flag-quiz/index.html" },
    { "source": "/hot-dog-or-not", "destination": "/hot-dog-or-not/index.html" },
    { "source": "/summer-aura", "destination": "/summer-aura/index.html" },
    { "source": "/emoji-decoder", "destination": "/emoji-decoder/index.html" }
  ]
}
